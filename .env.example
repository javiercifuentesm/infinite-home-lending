# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Agent V3 — OpenAI Responses API (server only; never expose to Vite client bundle)
OPENAI_API_KEY=""
# Optional — defaults to gpt-4o in code when unset
OPENAI_AGENT_V3_MODEL="gpt-4o"
# Optional — chain Responses API across turns (app state remains source of truth)
OPENAI_AGENT_V3_USE_CONVERSATION_STATE="false"
# Optional — structured debug logs on the server
OPENAI_AGENT_V3_DEBUG="false"
# Optional — request timeout in ms
OPENAI_AGENT_V3_TIMEOUT_MS="60000"
# Express: local dev default. On Railway, use PORT (injected) — do not set AGENT_V3_SERVER_PORT unless needed.
AGENT_V3_SERVER_PORT="8787"
# Comma-separated extra CORS origins (optional), e.g. Vercel preview: https://ihl-xxx.vercel.app
# CORS_ORIGINS=

# Where leads.jsonl lives. Default: <cwd>/data. On Railway, mount a volume and set e.g. LEADS_DATA_DIR=/data
# LEADS_DATA_DIR=

# === Client (Vite) — set in Vercel for production build ===
# Public Railway API origin, no trailing slash. Empty in dev = use same-origin + Vite /api proxy.
# VITE_API_BASE_URL="https://your-app.up.railway.app"

# AWS S3 — optional document upload (contact flow + presigned GET in advisor email)
# Use a private bucket; IAM policy: s3:PutObject, s3:GetObject on bucket/prefix only
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# Lead email (Resend) — server reads from project root .env via src/server/loadEnv.ts
# No quotes around values. One variable per line.
RESEND_API_KEY=
RESEND_FROM=Infinite Home Lending <onboarding@resend.dev>
LEAD_ADVISOR_EMAIL=
# Optional: DEBUG_SUMMARY=true returns HTML instead of sending email (API testing only)
# DEBUG_SUMMARY=

# Client — set to 1 to use /api/agent-v3 (proxy to server in dev)
VITE_AGENT_V3_API="0"
# Optional absolute API origin for agent-v3 only (if set, falls back to VITE_API_BASE_URL in client)
VITE_AGENT_V3_API_URL=""
# Dev-only: show LLM vs deterministic badge + collapsible panel (no effect in prod unless UI reads it)
VITE_AGENT_V3_DEBUG_UI="0"
# Dev-only: force deterministic API path (sends X-Agent-V3-Mode: deterministic)
VITE_AGENT_V3_FORCE_DETERMINISTIC="0"
# Server: include debug JSON on API responses when NODE_ENV=production (optional opt-in)
AGENT_V3_DEBUG_RESPONSES="0"
